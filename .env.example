# S3 — MinIO defaults (docker-compose.yml) work for local dev
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=dropsite
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=dropsite
AWS_SECRET_ACCESS_KEY=dropsite-secret

# Database
DATABASE_URL=postgresql://dropsite:dropsite@localhost:5432/dropsite

# Upload limits / retention
MAX_FILE_SIZE_MB=50
MAX_FILE_COUNT=500
RETENTION_COUNT=10

# In-memory LRU file cache (number of files)
LRU_MAX_SIZE=200

# Sessions (CHANGE in production — used to sign session cookies)
SESSION_SECRET=dev-insecure-change-me
SESSION_MAX_AGE=28800

# LDAP (leave LDAP_URL empty to disable LDAP)
LDAP_URL=
LDAP_USER_DN_TEMPLATE=uid={username},ou=people,dc=corp
LDAP_GROUP_BASE=ou=groups,dc=corp
LDAP_GROUP_CACHE_SECONDS=300

# Superadmin break-glass — bypasses LDAP, disabled unless BOTH are set.
# Generate the hash:  python -m app.auth hash '<password>'
# NEVER commit a real hash to git; set these via an OpenShift secret.
SUPERADMIN_USER=
SUPERADMIN_PWHASH=
